# Environment variables example for Cloud Shakes Backend
# IMPORTANT: Use strong, unique values in production!

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/cloud_shakes"

# JWT Configuration - Use a strong secret (at least 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this-too"
JWT_REFRESH_EXPIRES_IN="30d"

# File Upload Configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="100MB"
ALLOWED_FILE_TYPES="image/*,video/*,audio/*,application/pdf,text/*,.doc,.docx,.xls,.xlsx,.ppt,.pptx"
MAX_FILES_PER_REQUEST="20"

# Server Configuration
PORT=5000
NODE_ENV="development"
API_VERSION="v1"

# CORS Configuration - Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX="5"
AUTH_RATE_LIMIT_WINDOW="900000"
UPLOAD_RATE_LIMIT_MAX="10"
UPLOAD_RATE_LIMIT_WINDOW="60000"

# Security Configuration
BCRYPT_ROUNDS="12"
SESSION_SECRET="your-session-secret-change-this"
CSRF_SECRET="your-csrf-secret-change-this"

# Encryption at Rest (Optional but recommended)
ENCRYPTION_ENABLED="false"
ENCRYPTION_KEY="your-32-character-hex-encryption-key-here"
ENCRYPTION_ALGORITHM="aes-256-gcm"

# Storage (Optional - for cloud storage)
# MINIO_ENDPOINT="localhost:9000"
# MINIO_ACCESS_KEY="your-access-key"
# MINIO_SECRET_KEY="your-secret-key"
# MINIO_BUCKET="cloud-shakes"
# MINIO_USE_SSL="false"

# Email (Optional - for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@yourdomain.com"

# Feature Flags
ENABLE_REGISTRATION="true"
ENABLE_FILE_SHARING="true"
ENABLE_PUBLIC_LINKS="true"
REQUIRE_EMAIL_VERIFICATION="false"

# Logging Configuration
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"
ENABLE_REQUEST_LOGGING="false"

# Analytics (Optional)
# GOOGLE_ANALYTICS_ID=""
# SENTRY_DSN=""

# Backup Configuration
# BACKUP_SCHEDULE="0 2 * * *" # Daily at 2 AM
# BACKUP_RETENTION_DAYS="30"
# BACKUP_PATH="./backups"
