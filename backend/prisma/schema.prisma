generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                    @id @default(uuid())
  username               String                    @unique
  email                  String?                   @unique
  password               String
  displayName            String                    @default("User")
  avatar                 String? // URL or file ID for profile picture
  isAdmin                Boolean                   @default(false)
  isActive               Boolean                   @default(true)
  storageLimit           BigInt                    @default(53687091200) // 50 GB in bytes
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  files                  File[]
  folders                Folder[]
  links                  Link[]
  documents              Document[]
  spreadsheets           Spreadsheet[]
  presentations          Presentation[]
  notes                  Note[]
  calendarEvents         CalendarEvent[]
  apiFlows               ApiFlow[]
  activities             Activity[]
  roles                  UserRole[]
  conversations          ConversationParticipant[]
  messages               Message[]
  reactions              MessageReaction[]
  status                 UserStatus?
  invitesCreated         Invite[]                  @relation("InvitesCreated")
  createdConversations   Conversation[]            @relation("ConversationsCreated")
  modifiedFiles          File[]                    @relation("FileLastModifiedBy")
  modifiedDocuments      Document[]                @relation("DocumentLastModifiedBy")
  modifiedNotes          Note[]                    @relation("NoteLastModifiedBy")
  modifiedCalendarEvents CalendarEvent[]           @relation("CalendarEventLastModifiedBy")
  fileShares             FileShare[]
  brandingUpdates        Branding[]                @relation("BrandingUpdatedBy")
  cloudSettingsUpdates   CloudSettings[]           @relation("CloudSettingsUpdatedBy")
  backupsInitiated       Backup[]                  @relation("BackupInitiator")
  blogPosts              BlogPost[]
}

model Folder {
  id        String     @id @default(uuid())
  name      String
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id])
  parentId  String?
  parent    Folder?    @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("SubFolders")
  links     Link[]
  files     File[]
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model File {
  id               String      @id @default(uuid())
  originalName     String
  storedName       String      @unique // Name in MinIO
  mimeType         String
  size             BigInt
  ownerId          String
  owner            User        @relation(fields: [ownerId], references: [id])
  folderId         String?
  folder           Folder?     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  hideFromRecent   Boolean     @default(false)
  lastModifiedById String?
  lastModifiedBy   User?       @relation("FileLastModifiedBy", fields: [lastModifiedById], references: [id])
  createdAt        DateTime    @default(now())
  links            Link[]
  shares           FileShare[]
}

model Link {
  id             String    @id @default(nanoid(10)) // Short code
  fileId         String?
  file           File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  documentId     String?
  document       Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type           String    @default("file") // "file", "folder", or "document"
  password       String? // Optional hashed password
  expiresAt      DateTime?
  directDownload Boolean   @default(false)
  isEmbed        Boolean   @default(false)
  customSlug     String?   @unique // Custom URL slug
  views          Int       @default(0)
  createdAt      DateTime  @default(now())
  creatorId      String
  creator        User      @relation(fields: [creatorId], references: [id])
}

// ── Instance Branding (Name + Logo) ───────────────────────────────────
// Single-row config used by the frontend to show custom branding.
model Branding {
  id          String   @id @default("default")
  cloudName   String   @default("Cloud Shakes")
  logoUrl     String? // Public URL for the logo (recommended: https URL)
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("BrandingUpdatedBy", fields: [updatedById], references: [id])
}

// ── Cloud Limits (storage + bandwidth) ────────────────────────────────
model CloudSettings {
  id                String   @id @default("default")
  // If null => unlimited
  storageLimitBytes BigInt?
  // If null => use env default. If 0 => unlimited/no throttle.
  maxUploadSpeedKB  Int?
  updatedAt         DateTime @updatedAt
  updatedById       String?
  updatedBy         User?    @relation("CloudSettingsUpdatedBy", fields: [updatedById], references: [id])
}

// ── Phase 2: Documents ───────────────────────────────────────────────
model Document {
  id               String            @id @default(uuid())
  title            String            @default("Sin título")
  content          Json              @default("{}") // Rich text content (JSON de TipTap)
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id])
  folderId         String?
  folder           Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  lastModifiedById String?
  lastModifiedBy   User?             @relation("DocumentLastModifiedBy", fields: [lastModifiedById], references: [id])
  links            Link[] // Links that share this document
  versions         DocumentVersion[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([ownerId])
}

// Versionado de documentos
model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    Json // Snapshot del contenido en JSON
  title      String // Snapshot del título
  createdAt  DateTime @default(now())

  @@index([documentId])
}

// ── Phase 3: Spreadsheet ───────────────────────────────────────────────
model Spreadsheet {
  id        String   @id @default(uuid())
  title     String   @default("Sin título")
  data      Json     @default("{}") // Grid data + formulas
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ── Phase 4: Presentations ─────────────────────────────────────────────
model Presentation {
  id        String   @id @default(uuid())
  title     String   @default("Sin título")
  slides    Json     @default("[]") // Array de slides con contenido TipTap JSON
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ── Phase 5: Notes ───────────────────────────────────────────────────
model Note {
  id               String   @id @default(uuid())
  title            String   @default("")
  content          String   @default("")
  scope            String   @default("private") // private, workspace
  color            String   @default("default") // default, blue, green, yellow, red, purple
  pinned           Boolean  @default(false)
  ownerId          String
  owner            User     @relation(fields: [ownerId], references: [id])
  lastModifiedById String?
  lastModifiedBy   User?    @relation("NoteLastModifiedBy", fields: [lastModifiedById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ownerId])
  @@index([scope, updatedAt])
}

// ── Phase 4: Calendar ────────────────────────────────────────────────
model CalendarEvent {
  id               String    @id @default(uuid())
  title            String
  description      String?
  startDate        DateTime
  endDate          DateTime?
  allDay           Boolean   @default(false)
  pinned           Boolean   @default(false)
  color            String    @default("primary") // primary, blue, green, yellow, red, purple
  reminderMinutes  Int? // Minutes before event to show reminder (null = no reminder)
  reminderSent     Boolean   @default(false) // Track if reminder was sent
  ownerId          String
  owner            User      @relation(fields: [ownerId], references: [id])
  lastModifiedById String?
  lastModifiedBy   User?     @relation("CalendarEventLastModifiedBy", fields: [lastModifiedById], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([ownerId, startDate])
  @@index([startDate, reminderSent])
}

// ── Phase 5: API Flows ────────────────────────────────────────────────
model ApiFlow {
  id            String   @id @default(uuid())
  name          String
  description   String   @default("")
  blocks        Json     @default("[]") // Array of ApiBlock objects
  endpoint      String?
  method        String?  @default("GET") // GET, POST, PUT, DELETE
  deployed      Boolean  @default(false)
  apiKey        String?  @unique
  apiUrl        String?
  policies      Json     @default("{}") // ApiPolicy object
  selectedFiles Json     @default("[]") // Array of file IDs
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([apiKey])
}

// ── Activity Log (Nextcloud-like feature) ────────────────────────────────
model Activity {
  id           String   @id @default(uuid())
  type         String // 'file_upload', 'file_delete', 'file_download', 'folder_create', 'folder_delete', 'link_create', 'document_create', 'note_create', etc.
  action       String // Human-readable action description
  resourceId   String? // ID of the resource (file, folder, etc.)
  resourceType String? // 'file', 'folder', 'document', 'note', 'link', etc.
  resourceName String? // Name of the resource
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  metadata     Json? // Additional metadata (JSON)
  createdAt    DateTime @default(now())

  @@index([ownerId, createdAt])
  @@index([createdAt])
}

// ── IAM: Roles & Permissions ────────────────────────────────────────────────
model Role {
  id          String           @id @default(uuid())
  name        String
  description String?
  color       String?          @default("#7289DA")
  level       Int? // Nivel del 1-5 para herencia acumulativa
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  fileShares  FileShare[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

// ── File Sharing ─────────────────────────────────────────────────────────────
enum SharePermission {
  READ
  EDIT
  FULL
}

model FileShare {
  id         String          @id @default(uuid())
  fileId     String
  userId     String? // Usuario específico (nullable si es por rol)
  roleId     String? // Rol específico (nullable si es por usuario)
  permission SharePermission @default(READ)
  createdAt  DateTime        @default(now())
  createdBy  String
  file       File            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user       User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role?           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([fileId, userId])
  @@unique([fileId, roleId])
}

model Invite {
  id          String    @id @default(uuid())
  email       String?
  username    String?
  roles       Json
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdById String
  createdBy   User      @relation("InvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

// ── Chat: Conversations & Messages ────────────────────────────────────────────────
model Conversation {
  id            String                    @id @default(uuid())
  name          String?
  isGroup       Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  createdById   String
  createdBy     User                      @relation("ConversationsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  participants  ConversationParticipant[]
  messages      Message[]
  lastMessageAt DateTime?

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           String       @default("member") // member, admin
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime     @default(now())
  notifications  String       @default("all") // all, mentions, none
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String            @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           String            @default("text") // text, file, system
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions      MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

// ── User Status ───────────────────────────────────────────────────────────────────
model UserStatus {
  id       String   @id @default(uuid())
  userId   String   @unique
  status   String   @default("online") // online, away, dnd, offline
  lastSeen DateTime @default(now())
  custom   String?
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Plugin System ───────────────────────────────────────────────────────────────

model Plugin {
  id          String  @id @default(uuid())
  name        String  @unique
  displayName String
  description String?
  author      String
  authorId    String?
  type        String  @default("backend") // backend, frontend, fullstack
  category    String  @default("integration") // integration, automation, analytics, ai, storage, ui
  website     String?
  repository  String?
  license     String  @default("MIT")
  isPublic    Boolean @default(false)
  isFeatured  Boolean @default(false)
  isApproved  Boolean @default(false)
  status      String  @default("draft") // draft, pending, approved, rejected, deprecated

  // SDK
  sdkVersion    String  @default("1.0.0")
  minSdkVersion String?

  // Resources
  cpuLimit     String @default("500m")
  memoryLimit  String @default("512Mi")
  storageLimit String @default("1Gi")

  // Security
  permissions    String[] @default([])
  allowedDomains String[] @default([])

  // Stats
  downloads   Int   @default(0)
  rating      Float @default(0)
  ratingCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions      PluginVersion[]
  installations UserPlugin[]
}

model PluginVersion {
  id       String @id @default(uuid())
  pluginId String
  plugin   Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  version  String

  // Build info
  buildStatus String  @default("pending") // pending, building, success, failed
  buildLog    String?

  // Artifact
  artifactUrl  String? // URL to ZIP file in MinIO
  artifactSize BigInt?
  checksum     String?

  // Docker
  dockerImage String?
  dockerfile  String?

  // Metadata
  changelog       String?
  minAppVersion   String?
  deprecated      Boolean @default(false)
  deprecationNote String?

  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@unique([pluginId, version])
}

model UserPlugin {
  id       String @id @default(uuid())
  userId   String
  pluginId String
  plugin   Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  version  String

  // Installation status
  status       String  @default("installed") // installed, enabled, disabled, error
  errorMessage String?

  // Container info
  containerId     String?
  containerStatus String?
  containerIp     String?
  containerPort   Int?

  // Config
  config Json @default("{}")

  // Stats
  lastUsedAt DateTime?
  useCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pluginId])
}

model PluginLog {
  id           String   @id @default(uuid())
  userPluginId String
  level        String // info, warn, error
  message      String
  metadata     Json?
  timestamp    DateTime @default(now())
}

// ── Blog Posts ─────────────────────────────────────────────────────────────
model BlogPost {
  id     String @id @default(uuid())
  slug   String @unique // URL-friendly identifier
  locale String @default("es") // es | en

  // Title & Content
  title      String
  excerpt    String? // Short description for cards
  content    String // Markdown/HTML content
  coverImage String? // URL to cover image

  // SEO
  seoTitle       String?
  seoDescription String?

  // Metadata
  author   String   @default("Cloud Shakes")
  tags     String[] @default([]) // Array of tags
  category String   @default("general")

  // Status
  published Boolean @default(false)
  featured  Boolean @default(false) // Featured post

  // Timestamps
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  authorId   String?
  authorUser User?   @relation(fields: [authorId], references: [id])
}

// ── Backups ─────────────────────────────────────────────────────────────
model BackupConfig {
  id      String  @id @default(uuid())
  type    String  @default("local") // local, s3, ssh
  name    String
  enabled Boolean @default(false)

  // S3 (MinIO) config
  s3Endpoint       String?
  s3Bucket         String?
  s3AccessKey      String? // Encrypted string
  s3SecretKey      String? // Encrypted string
  s3Region         String? @default("us-east-1")
  s3ForcePathStyle Boolean @default(true)

  // SSH config
  sshHost     String?
  sshPort     Int?    @default(22)
  sshUser     String?
  sshPassword String? // Encrypted string
  sshKey      String? @db.Text // Encrypted private key
  sshPath     String? // Path on remote server

  // Local config
  localPath String?

  // Schedule (cron expression)
  schedule  String? @default("0 0 * * *") // Daily by default
  retention Int     @default(7) // Keep last 7 backups

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  backups Backup[]
}

model Backup {
  id          String       @id @default(uuid())
  configId    String
  config      BackupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  status      String       @default("pending") // pending, in_progress, success, failed
  filename    String?
  size        BigInt?
  error       String?
  log         String?      // Log output from backup
  startedAt   DateTime     @default(now())
  completedAt DateTime?
  expiresAt   DateTime?
  initiatorId String? // If triggered manually
  initiator   User?        @relation("BackupInitiator", fields: [initiatorId], references: [id], onDelete: SetNull)
}

// ── Push Notifications ─────────────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   // Push service endpoint URL
  p256dh    String   // Public key for encryption
  auth      String   // Auth secret
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint])
}
