# Database
POSTGRES_USER=cloudadmin
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=clouddb

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password
MINIO_BUCKET_NAME=my-cloud-files
# Add these to control where MinIO is accessible from externally if needed (Used in docker-compose.yml)
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# Backend
JWT_SECRET=your_super_secret_jwt_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
FRONTEND_URL=http://localhost:9090

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000

# Additional for production
POSTGRES_PASSWORD_ENCODED=your_secure_db_password  # Same as POSTGRES_PASSWORD, URL encoded if needed
MINIO_EXTERNAL_ENDPOINT=localhost
MINIO_EXTERNAL_PORT=9000
MINIO_EXTERNAL_USE_SSL=false
ALLOWED_ORIGINS=http://localhost:9090
COOKIE_DOMAIN=